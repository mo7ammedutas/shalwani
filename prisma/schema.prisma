// Shalwani commerce schema — PostgreSQL (Neon/Supabase/Vercel Postgres).
// Point DATABASE_URL at your Postgres instance for both dev and prod
// (free Neon branches work well for local development — see README).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                 String         @id @default(cuid())
  slug               String         @unique
  nameAr             String
  nameEn             String
  descriptionAr      String
  descriptionEn      String
  category           String         @default("bashmina") // "turma" | "bashmina" — the shop's two massar lines
  color              String // slug into the shared color taxonomy (midnight, lazuli, ...)
  embroidery         String // slug into the embroidery taxonomy (kashmiri, geometric, ...)
  priceBaisa         Int // integer baisa; 1 OMR = 1000 baisa
  originalPriceBaisa Int? // pre-sale price, shown struck through; null = not on offer
  images             String // JSON array of image paths, primary first
  stock              Int            @default(0)
  featured           Boolean        @default(false)
  archived           Boolean        @default(false) // hidden from the storefront; used when a product with orders can't be hard-deleted
  createdAt          DateTime       @default(now())
  orderItems         OrderItem[]
  wishlistedBy       WishlistItem[]
  reviews            Review[]
}

model Customer {
  id            String               @id @default(cuid())
  name          String
  phone         String               @unique
  email         String?
  passwordHash  String? // set once the customer registers; null = guest-only record
  notes         String? // admin-only CRM note, never shown to the customer
  loyaltyPoints Int                  @default(0) // current redeemable balance
  createdAt     DateTime             @default(now())
  orders        Order[]
  wishlist      WishlistItem[]
  loyaltyLog    LoyaltyTransaction[]
  reviews       Review[]
}

/**
 * Audit trail for every points movement — the balance on Customer is the
 * cached sum, this table is the source of truth for "where did they come
 * from". kind: earn | redeem | adjust.
 */
model LoyaltyTransaction {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  orderId    String?
  kind       String // "earn" | "redeem" | "adjust"
  points     Int // positive for earn, negative for redeem
  createdAt  DateTime @default(now())
}

model WishlistItem {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
}

model Order {
  id                   String               @id @default(cuid())
  orderNumber          String               @unique // SHW-XXXXXX
  customerId           String
  customer             Customer             @relation(fields: [customerId], references: [id])
  status               String               @default("pending") // pending | paid | shipped | delivered | failed | cancelled
  totalBaisa           Int // grand total: products + gift add-ons + shipping fee
  shippingAddress      String
  notes                String?
  locale               String               @default("ar")
  thawaniSessionId     String?              @unique
  isGift               Boolean              @default(false)
  giftMessage          String?
  recipientName        String?
  shippingZone         String               @default("oman") // "oman" | "gulf"
  shippingFeeBaisa     Int                  @default(0)
  giftAddonsTotalBaisa Int                  @default(0)
  vatBaisa             Int                  @default(0)
  couponCode           String? // snapshot of the applied coupon's code
  discountBaisa        Int                  @default(0) // coupon + redeemed loyalty points combined
  redeemedPoints       Int                  @default(0) // loyalty points spent on this order
  trackingNumber       String? // carrier reference, free text
  shippedAt            DateTime?
  deliveredAt          DateTime?
  reminderSentAt       DateTime? // abandoned-checkout reminder timestamp (sent at most once)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  items                OrderItem[]
  giftAddons           OrderGiftAddon[]
  transactions         PaymentTransaction[]
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id])
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  quantity       Int
  unitPriceBaisa Int // price at the moment of purchase
}

model GiftAddon {
  id          String           @id @default(cuid())
  slug        String           @unique
  nameAr      String
  nameEn      String
  priceBaisa  Int
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  orderAddons OrderGiftAddon[]
}

model OrderGiftAddon {
  id         String     @id @default(cuid())
  orderId    String
  order      Order      @relation(fields: [orderId], references: [id])
  addonId    String?
  addon      GiftAddon? @relation(fields: [addonId], references: [id])
  nameAr     String // snapshot at time of order
  nameEn     String
  priceBaisa Int
}

model PaymentTransaction {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  provider   String   @default("thawani")
  sessionId  String
  status     String // created | paid | failed | cancelled
  rawPayload String // full JSON payload for auditing
  createdAt  DateTime @default(now())
}

model BespokeRequest {
  id          String   @id @default(cuid())
  name        String
  phone       String
  occasion    String
  preferences String
  status      String   @default("new") // new | quoted | paid
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String
  message   String
  createdAt DateTime @default(now())
}

/**
 * Staff account — replaces the single shared ADMIN_PASSWORD.
 */
model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String // "admin" | "manager" | "support" | "content" | "warehouse"
  active       Boolean  @default(true)
  totpSecret   String? // base32 TOTP secret; null = 2FA not enrolled
  createdAt    DateTime @default(now())
}

/**
 * Discount codes. kind: "percent" (value = 1–100), "fixed" (value = baisa
 * off the goods subtotal), "freeShipping" (value ignored).
 */
model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique // stored uppercase
  kind          String // "percent" | "fixed" | "freeShipping"
  value         Int       @default(0)
  minOrderBaisa Int       @default(0) // goods subtotal threshold to qualify
  maxUses       Int? // null = unlimited
  usedCount     Int       @default(0)
  active        Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
}

/**
 * Product review — only customers with a paid order containing the product
 * may submit; only approved reviews render on the storefront.
 */
model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  rating     Int // 1–5
  text       String
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([productId, customerId]) // one review per customer per product
}

/**
 * Lookbook image — uploaded independently of products so the gallery can
 * show workshop scenes and finished commissions that aren't for sale.
 */
model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  captionAr String   @default("")
  captionEn String   @default("")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

/**
 * Fixed-window rate limiting backed by Postgres — no Redis needed, and it
 * works across serverless instances. key = "<scope>:<identifier>".
 */
model RateLimit {
  key         String   @id
  windowStart DateTime
  count       Int      @default(0)
}

/**
 * Simple key/value store editable from /admin/settings — string or
 * JSON.stringify'd structured values, read at runtime instead of hardcoded
 * constants for logo, contact channels, tax and shipping.
 */
model Setting {
  key   String @id
  value String
}

/**
 * One row per calendar day, incremented by a storefront beacon.
 * Powers an approximate conversion-rate metric in analytics.
 */
model PageView {
  day   String @id // "YYYY-MM-DD"
  count Int    @default(0)
}
