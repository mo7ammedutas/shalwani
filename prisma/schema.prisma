// Shalwani commerce schema — PostgreSQL (Neon/Supabase/Vercel Postgres).
// Point DATABASE_URL at your Postgres instance for both dev and prod
// (free Neon branches work well for local development — see README).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String      @id @default(cuid())
  slug          String      @unique
  nameAr        String
  nameEn        String
  descriptionAr String
  descriptionEn String
  color         String // slug into the shared color taxonomy (midnight, lazuli, ...)
  embroidery    String // slug into the embroidery taxonomy (kashmiri, geometric, ...)
  priceBaisa    Int // integer baisa; 1 OMR = 1000 baisa
  images        String // JSON array of image paths, primary first
  stock         Int         @default(0)
  featured      Boolean     @default(false)
  archived      Boolean     @default(false) // hidden from the storefront; used when a product with orders can't be hard-deleted
  createdAt     DateTime    @default(now())
  orderItems    OrderItem[]
  wishlistedBy  WishlistItem[]
}

model Customer {
  id           String         @id @default(cuid())
  name         String
  phone        String         @unique
  email        String?
  passwordHash String? // set once the customer registers; null = guest-only record
  notes        String? // admin-only CRM note, never shown to the customer
  createdAt    DateTime       @default(now())
  orders       Order[]
  wishlist     WishlistItem[]
}

model WishlistItem {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
}

model Order {
  id                   String               @id @default(cuid())
  orderNumber          String               @unique // SHW-XXXXXX
  customerId           String
  customer             Customer             @relation(fields: [customerId], references: [id])
  status               String               @default("pending") // pending | paid | failed | cancelled
  totalBaisa           Int // grand total: products + gift add-ons + shipping fee
  shippingAddress      String
  notes                String?
  locale               String               @default("ar")
  thawaniSessionId     String?              @unique
  isGift               Boolean              @default(false)
  giftMessage          String?
  recipientName        String?
  shippingZone         String               @default("oman") // "oman" | "gulf"
  shippingFeeBaisa     Int                  @default(0)
  giftAddonsTotalBaisa Int                  @default(0)
  vatBaisa             Int                  @default(0)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  items                OrderItem[]
  giftAddons           OrderGiftAddon[]
  transactions         PaymentTransaction[]
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id])
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  quantity       Int
  unitPriceBaisa Int // price at the moment of purchase
}

model GiftAddon {
  id          String           @id @default(cuid())
  slug        String           @unique
  nameAr      String
  nameEn      String
  priceBaisa  Int
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  orderAddons OrderGiftAddon[]
}

model OrderGiftAddon {
  id         String     @id @default(cuid())
  orderId    String
  order      Order      @relation(fields: [orderId], references: [id])
  addonId    String?
  addon      GiftAddon? @relation(fields: [addonId], references: [id])
  nameAr     String // snapshot at time of order
  nameEn     String
  priceBaisa Int
}

model PaymentTransaction {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  provider   String   @default("thawani")
  sessionId  String
  status     String // created | paid | failed | cancelled
  rawPayload String // full JSON payload for auditing
  createdAt  DateTime @default(now())
}

model BespokeRequest {
  id          String   @id @default(cuid())
  name        String
  phone       String
  occasion    String
  preferences String
  status      String   @default("new") // new | quoted | paid
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String
  message   String
  createdAt DateTime @default(now())
}

/** Staff account — replaces the single shared ADMIN_PASSWORD. */
model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String // "admin" | "manager" | "support" | "content" | "warehouse"
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

/** Simple key/value store editable from /admin/settings — string or
 * JSON.stringify'd structured values, read at runtime instead of hardcoded
 * constants for logo, contact channels, tax and shipping. */
model Setting {
  key   String @id
  value String
}

/** One row per calendar day, incremented by a storefront beacon.
 * Powers an approximate conversion-rate metric in analytics. */
model PageView {
  day   String @id // "YYYY-MM-DD"
  count Int    @default(0)
}
