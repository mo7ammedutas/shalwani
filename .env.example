# ── Database ────────────────────────────────────────────────
# PostgreSQL everywhere (free Neon branch works for local dev):
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/shalwani?sslmode=require"
# (SQLite is no longer supported — the schema targets PostgreSQL)


# ── Site ────────────────────────────────────────────────────
# Absolute origin used for Thawani success/cancel URLs and SEO tags.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Thawani Pay ─────────────────────────────────────────────
# Get merchant keys from the Thawani dashboard (see README §Payments).
# UAT/Sandbox base URL:  https://uatcheckout.thawani.om/api/v1
# Production base URL:   https://checkout.thawani.om/api/v1
THAWANI_BASE_URL="https://uatcheckout.thawani.om/api/v1"
THAWANI_SECRET_KEY="your-secret-key"
THAWANI_PUBLISHABLE_KEY="your-publishable-key"

# Set to 1 to exercise the full checkout flow locally without calling
# Thawani at all (used by the test suite). Set to 0 / remove for real
# sandbox or production payments.
THAWANI_MOCK="1"

# ── Admin panel ───────────────────────────────────
ADMIN_PASSWORD="choose-a-strong-password"
# Random 32+ bytes; generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET="generate-a-random-secret"
