# ── Database ────────────────────────────────────────────────
# PostgreSQL everywhere (free Neon branch works for local dev):
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/shalwani?sslmode=require"
# (SQLite is no longer supported — the schema targets PostgreSQL)

# Isolated database for the e2e suite — STRONGLY recommended so tests never
# touch production data. Create a branch in the Neon console (Branches →
# New branch, from main) or `npx neonctl branches create --name test`,
# then paste that branch's connection string here. When set, `npm run
# test:e2e` migrates + seeds + runs entirely against it.
# TEST_DATABASE_URL="postgresql://USER:PASSWORD@TEST-BRANCH-HOST/neondb?sslmode=require"


# ── Site ────────────────────────────────────────────────────
# Absolute origin used for Thawani success/cancel URLs and SEO tags.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Thawani Pay ─────────────────────────────────────────────
# Get merchant keys from the Thawani dashboard (see README §Payments).
# UAT/Sandbox base URL:  https://uatcheckout.thawani.om/api/v1
# Production base URL:   https://checkout.thawani.om/api/v1
THAWANI_BASE_URL="https://uatcheckout.thawani.om/api/v1"
THAWANI_SECRET_KEY="your-secret-key"
THAWANI_PUBLISHABLE_KEY="your-publishable-key"

# Set to 1 to exercise the full checkout flow locally without calling
# Thawani at all (used by the test suite). Set to 0 / remove for real
# sandbox or production payments.
THAWANI_MOCK="1"

# ── Admin panel ───────────────────────────────────
ADMIN_PASSWORD="choose-a-strong-password"
# Random 32+ bytes; generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET="generate-a-random-secret"

# ── Notifications (optional — silently skipped when unset) ──
# Email via Resend (resend.com). EMAIL_FROM must be a verified domain
# sender, e.g. "Shalwani <orders@yourdomain.com>".
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Shalwani <orders@yourdomain.com>"
# SMS via Twilio (twilio.com). TWILIO_FROM is your Twilio number.
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_FROM="+1..."

# ── Cron (abandoned-cart reminders) ─────────────────────────
# Vercel sends this as a Bearer token to /api/cron/* routes; set the same
# value in the Vercel project env. Generate like AUTH_SECRET.
# CRON_SECRET="generate-a-random-secret"
